# sub2socks5 部署配置示例
# 用法: cp .env.example .env，按场景填值
# .env 已被 .gitignore 排除，不会提交到仓库。

# ============ 通用 ============

# 时区
TZ=Asia/Shanghai

# Web UI 用户名 / 密码鉴权（必填，留空启动会失败）。
# 行为：USERNAME 留空默认 admin；PASSWORD 必须填。
# 生成强密码：openssl rand -base64 24
SUB2SOCKS5_USERNAME=admin
SUB2SOCKS5_PASSWORD=

# ============ 监听 ============
# host 网络模式下，容器直接共享宿主机网络栈，无端口映射。
# 容器监听什么端口，宿主机就开什么端口。

# Web UI 监听地址：
#   127.0.0.1（推荐）→ 仅本机访问，配 ssh -L 60080:127.0.0.1:60080 user@vps 隧道使用
#   0.0.0.0          → 暴露到 LAN/公网（必须配 USERNAME+PASSWORD + 防火墙白名单）
SUB2SOCKS5_HOST=127.0.0.1
SUB2SOCKS5_PORT=60080

# SOCKS5/HTTP 代理端口范围：60081-60100（在 Web UI 内创建端口时使用）
# 公网放行示例（ufw）：
#   sudo ufw allow 60081:60100/tcp
