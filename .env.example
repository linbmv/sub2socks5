# sub2socks5 部署配置示例
# 用法: cp .env.example .env，按场景填值
# .env 已被 .gitignore 排除，不会提交到仓库。

# ============ 通用 ============

# 时区
TZ=Asia/Shanghai

# Web UI 用户名 / 密码鉴权（公网/CF Tunnel 部署强烈建议）。
# 行为：PASSWORD 留空 → 鉴权关闭；填了 → 启用。USERNAME 留空默认 admin。
# 生成强密码：openssl rand -base64 24
SUB2SOCKS5_USERNAME=
SUB2SOCKS5_PASSWORD=

# Host 头白名单（仅鉴权启用时生效，防 DNS rebinding）。
# 默认已含 localhost / 127.0.0.1 / ::1，无需重复填。
# CF Tunnel 模式必填回源域名，例如: sub2socks5.your-domain.com
# LAN 模式填 LAN IP，例如: 192.168.1.10
# 多个用逗号分隔。
SUB2SOCKS5_ALLOWED_HOSTS=

# 复制 SOCKS5 时把监听 0.0.0.0/:: 替换为该地址（VPS 公网域名）。
SUB2SOCKS5_EXTERNAL_HOST=

# 部署横幅（顶部提示），格式 "level|message"，level 取 info/warning。
# 示例: SUB2SOCKS5_DEPLOYMENT_HINT=info|CF Tunnel 模式：Web UI 经 Cloudflare 反代
SUB2SOCKS5_DEPLOYMENT_HINT=

# ============ 端口绑定 ============

# Web UI 端口绑定到宿主机的接口。
# 127.0.0.1（默认）→ 仅本机访问；CF Tunnel 同 docker network 仍走得通。
# 0.0.0.0          → 暴露到 LAN/公网（务必先设 USERNAME+PASSWORD + ALLOWED_HOSTS）。
WEBUI_BIND=127.0.0.1

# SOCKS5 端口绑定到宿主机的接口（默认 0.0.0.0 暴露给外部）。
SOCKS5_BIND=0.0.0.0

# ============ CF Tunnel ============

# 模式 A：本仓库自起 cloudflared 容器
#   docker compose --profile cf-tunnel up -d
# 把 CF Zero Trust → Tunnels 弹出的 token 填这里：
CF_TUNNEL_TOKEN=

# 模式 B：已有外部独立 cloudflared 容器
#   把 sub2socks5 加入该容器所在的 docker network，
#   然后在 CF Public Hostname URL 填 http://sub2socks5:18080
# 填 cloudflared 容器所在的 docker network 名（用 docker network ls 查看）
EXTERNAL_NETWORK=
