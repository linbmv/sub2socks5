# sub2socks5 部署配置示例
# 用法: cp .env.example .env，按场景填值
# .env 已被 .gitignore 排除，不会提交到仓库。

# ============ 通用 ============

# 时区
TZ=Asia/Shanghai

# Web UI 用户名 / 密码鉴权（LAN/公网部署强烈建议）。
# 行为：PASSWORD 留空 → 鉴权关闭；填了 → 启用。USERNAME 留空默认 admin。
# 生成强密码：openssl rand -base64 24
SUB2SOCKS5_USERNAME=
SUB2SOCKS5_PASSWORD=

# ============ 端口绑定 ============

# Web UI 端口绑定到宿主机的接口。
# 127.0.0.1（默认）→ 仅本机访问。
# 0.0.0.0          → 暴露到 LAN/公网（务必先设 USERNAME+PASSWORD）。
WEBUI_BIND=0.0.0.0

# SOCKS5 端口绑定到宿主机的接口（默认 0.0.0.0 暴露给外部）。
SOCKS5_BIND=0.0.0.0
